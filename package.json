{
  "name": "agent-news",
  "version": "1.28.1",
  "private": true,
  "scripts": {
    "wrangler": "set -a && . ./.env && set +a && npx wrangler",
    "build:frontend": "node scripts/build-frontend.mjs",
    "predev": "npm run build:frontend",
    "predeploy": "npm run build:frontend",
    "dev": "npm run wrangler -- dev",
    "deploy": "npm run wrangler -- deploy",
    "deploy:dry-run": "npm run wrangler -- deploy --dry-run",
    "dev:staging": "npm run wrangler -- dev --env staging",
    "deploy:dry-run:staging": "npm run wrangler -- deploy --dry-run --env staging",
    "check": "npm run typecheck && npm run lint",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf-typegen": "npm run wrangler -- types",
    "migrate": "set -a && . ./.env && set +a && npx tsx scripts/migrate-kv-to-do.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@cloudflare/vitest-pool-workers": "^0.13.2",
    "@cloudflare/workers-types": "^4.20241205.0",
    "@types/node": "^25.3.3",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.75.0"
  },
  "overrides": {
    "vite": "8.0.5"
  },
  "dependencies": {
    "@aibtc/tx-schemas": "^1.1.0",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@noble/secp256k1": "^2.1.0",
    "@scure/base": "^2.0.0",
    "@scure/btc-signer": "^2.0.1",
    "@stacks/blockchain-api-client": "^8.15.3",
    "@stacks/connect": "^8.2.6",
    "@stacks/transactions": "^7.4.0",
    "hono": "^4.12.12"
  }
}
